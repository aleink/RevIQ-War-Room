{
  "name": "reviq-command",
  "version": "1.0.0",
  "description": "RevIQ Command — Telegram bot + AI brain + Supabase + web dashboard for a 5-person launch team",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "bot": "node bot/index.js",
    "dev:bot": "node --watch bot/index.js",
    "dev:web": "cd web && npm run dev",
    "install:all": "npm install && cd web && npm install",
    "start": "node bot/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "grammy": "^1.27.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
