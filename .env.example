# ─────────────────────────────────────────────
# RevIQ Command — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# The Telegram group chat ID (negative number, e.g. -1001234567890)
# To find it: add @userinfobot to your group, it will print the chat ID
TEAM_CHAT_ID=

# ── AI ────────────────────────────────────────
# Claude API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────
# From Supabase project settings > API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=        # service_role key — keep secret, bot use only
SUPABASE_ANON_KEY=           # anon/public key — used by web dashboard client

# ── Web Dashboard ─────────────────────────────
# A random string — share once in Telegram group as the dashboard link
# Generate with: openssl rand -hex 32
DASHBOARD_TOKEN=

# Exposed to the Next.js frontend (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=    # Same value as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # Same value as SUPABASE_ANON_KEY

# ── Bot Behavior Config ───────────────────────
# Autonomous mode: "on" or "off". Team controls this at runtime via /listen and /silent
AUTONOMOUS_MODE=off

# Check for autonomous intervention every N messages (batch size)
AUTONOMOUS_MESSAGE_INTERVAL=10

# Also check every N minutes regardless of message count
AUTONOMOUS_TIME_INTERVAL=30

# Maximum unprompted messages per day (resets at midnight)
AUTONOMOUS_DAILY_LIMIT=3

# Daily morning nudge: "true" or "false"
DAILY_RECAP_ENABLED=false

# Time for daily morning message in 24h format (uses server timezone, set TZ accordingly)
DAILY_RECAP_TIME=09:00

# ── Deployment (Railway sets these automatically) ─
# Set manually only if deploying outside Railway
# PORT=3000
# NODE_ENV=production
# RAILWAY_STATIC_URL=   # Your Railway public URL for webhook registration
